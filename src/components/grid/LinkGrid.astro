---
export interface Props {
  items: {
    title: string;
    link: string;
    desc: string;
    tag?: string;
    stars?: number;
  }[];
}

const { items } = Astro.props;
---

<div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-8 mt-6">
  {
    items.map((item) => (
      <div class="space-y-1">
        <div class="flex items-start justify-between gap-2">
          <a
            href={item.link}
            target="_blank"
            class="font-medium text-text hover:text-myblue transition-colors"
          >
            {item.title}
          </a>
          <div class="flex items-center gap-1 shrink-0">
            {item.stars && (
              <div class="flex items-center gap-1 text-xs px-2 py-1 border dark:text-yellow dark:bg-neutral-800 dark:border-neutral-700 rounded">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                {item.stars.toLocaleString()}
              </div>
            )}
            {item.tag && (
              <div class="text-xs px-2 py-1 border dark:text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 rounded">
                {item.tag}
              </div>
            )}
          </div>
        </div>
        <div class="text-sm text-zinc-500">{item.desc}</div>
      </div>
    ))
  }
</div>
