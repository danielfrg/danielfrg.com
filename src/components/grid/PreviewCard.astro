---
export interface Props {
  title: string;
  desc: string;
  img: string;
  links: any;
  tag?: string;
  stars?: number;
}

const { title, desc, img, links, tag, stars } = Astro.props;
---

<div class="flex flex-col bg-[#27272A] p-1 prose prose-invert">
  <a href={links[0]?.href} class="flex relative border-0">
    <img src={img} class="w-full h-[160px] m-0 object-cover object-center my-0!" />
    {stars && (
      <div class="absolute top-2 left-2 flex items-center gap-1 text-xs px-2 py-1 border dark:text-yellow dark:bg-neutral-800 dark:border-neutral-700 rounded">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
        {stars.toLocaleString()}
      </div>
    )}
    {tag && (
      <div class="absolute top-2 right-2 text-xs px-2 py-1 border dark:text-gray-400 dark:bg-neutral-800 dark:border-neutral-700 rounded">
        {tag}
      </div>
    )}
  </a>
  <div class="flex flex-col px-2 py-2 text-center">
    <h3 class="uppercase m-0!">
      {title}
    </h3>
    <span class="font-mono text-sm">{desc}</span>

    <div class="flex flex-col gap-1 w-full h-full justify-center items-center">
      {
        links.map((link: any) => (
          <a href={link.href} class="underline hover:text-mywhite ">
            {link.text}
          </a>
        ))
      }
    </div>
  </div>
</div>
