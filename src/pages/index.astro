---
import Prose from "@layouts/Prose.astro";
import SocialLinks from "@components/SocialLinks.astro";
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from "@lib/consts";

let title = SITE_TITLE;
let description = SITE_DESCRIPTION;
let permalink = SITE_URL;
---

<Prose title={title} description={description} permalink={permalink}>
  <img
    id="background"
    src="/images/galaxy.webp"
    alt="background"
    class="appear duration-300 saturate-0 opacity-25 fixed inset-0 -z-10 h-full w-full object-cover"
  />

  <div class="breakout px-8">
    <div class="flex flex-col md:flex-row gap-8 px-8 max-w-4xl mx-auto items-center">
      <div class="flex-col my-auto">
        <h1 class="text-5xl font-extrabold tracking-tighter text-[#d4d4d8]">Daniel Rodriguez</h1>
        <div class="text-[#d4d4d8] text-lg font-light leading-loose mt-2">
          Engineer focused on building data tools for developers.
        </div>
      </div>
      <div class="w-1/2 md:w-1/3 shrink-0 rotate-6 transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] will-change-transform hover:rotate-1 hover:scale-110 hover:duration-700">
        <img
          class="w-full object-cover rounded-md"
          src="/images/profile.jpeg"
          alt="profile"
          width="512"
          height="512"
        />
      </div>
    </div>
  </div>
  <div class="text-xl leading-relaxed">
    <p class="">
      I work as a Product Manager for CUDA Python at NVIDIA.
    </p>
    <p class="">
    I created
            <a
              href="https://lapalabradeldia.com"
              class="font-bold text-lapalabragreen! hover:underline"
              target="_blank">La Palabra del día</a
            >
            and I build many other apps at <a href="https://inmatura.com">Inmatura</a>.
  </p>
  <p class="">
  I have worked in the data science / machine learning / data engineering / AI space
  for over 13 years as an engineer, devops, product manager, sales.
  </p>
  <p class="">
   I have <a href="/content">written and recoded some content</a> and <a href="/projects">built many projects</a>.
  </p>
  </div>

  <SocialLinks />
</Prose>
